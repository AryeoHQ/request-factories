{
    "name": "aryeo/request-factories",
    "type": "library",
    "repositories": {
        "tooling-laravel": {
            "type": "vcs",
            "url": "https://github.com/AryeoHQ/tooling-laravel"
        }
    },
    "require": {
        "laravel/framework": "^12.37"
    },
    "require-dev": {
        "orchestra/testbench": "^10.6",
        "aryeo/tooling-laravel": "0.0.31",
        "orchestra/testbench-core": "^10.7",
        "phpunit/phpunit": "^12.4.1",
        "pestphp/pest": "^4.1"
    },
    "autoload": {
        "psr-4": {
            "Support\\": "src/Support"
        },
        "exclude-from-classmap": [
            "*Test.php",
            "*TestCases.php",
            "/tests/"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "authors": [
        {
            "name": "Justin Seliga",
            "email": "justinsel@zillowgroup.com"
        }
    ],
    "minimum-stability": "stable",
    "config": {
        "allow-plugins": {
            "aryeo/tooling-laravel": true,
            "pestphp/pest-plugin": true
        }
    }
}
